# Rust
/target
**/*.rs.bk
Cargo.lock

# Python
__pycache__/
*.py[cod]
*.so
*.pyd
dist/
*.egg-info/
.venv/
venv/

# Test databases
*.sparrowdb/
*.db/
/tmp/sparrowdb-*

# Spill files (runtime, never durable)
/tmp/sparrowdb-spill-*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Benchmarks output
benches/output/
criterion/

# Large generated fixtures (generated on demand via gen-fixtures binary)
# Only small fixtures (social_small.json, deps_small.json) are committed.
tests/fixtures/social_10k.json
tests/fixtures/social_100k.json
tests/fixtures/deps_500.json
tests/fixtures/concepts_1k.json

# Node binding build artifacts (regenerated via napi build)
npm/sparrowdb/node_modules/
npm/sparrowdb/sparrowdb.node
npm/sparrowdb/*.darwin-arm64.node
npm/sparrowdb/*.darwin-x64.node
npm/sparrowdb/*.linux-*.node
npm/sparrowdb/*.win32-*.node
